{
  "name": "comphp/config-ini",
  "type": "library",
  "description": "Configuration Driver for CommonPHP which encodes/decodes the INI format",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Drivers\\Config\\INI\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Drivers\\Config\\INI\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/config": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}